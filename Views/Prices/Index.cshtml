@using System.Text.Json
@model PricesViewModel

<h1 class="text-center mb-4">
    Strømpriser
</h1>

<div class="card">
    <div class="card-body">
        <canvas id="priceChart"></canvas>
    </div>
</div>

@{
    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    var pricesJson = JsonSerializer.Serialize(Model.Prices, jsonOptions);
    var cheapestPeriodJson = JsonSerializer.Serialize(Model.CheapestPeriod, jsonOptions);
}

<script id="price-data" type="application/json">
    @Html.Raw(pricesJson)
</script>

<script id="optimal-period-data" type="application/json">
    @Html.Raw(cheapestPeriodJson)
</script>
