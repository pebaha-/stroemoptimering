@using System.Text.Json
@model PricesViewModel

@{
    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };
}

<div id="price-results">
    <script id="price-data" type="application/json">
            @Html.Raw(JsonSerializer.Serialize(Model.Prices, jsonOptions))
    </script>

    <div id="best-period"></div>

    <div class="card mb-4">
        <div class="card-body">
            <canvas class="price-chart"></canvas>
        </div>
    </div>
</div>

<h2 class="h4">Top 10 billigste perioder</h2>

<div id="optimal-periods"></div>

<template id="optimal-period-table-template">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Periode</th>
                <th>Pris</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</template>

<template id="optimal-period-row-template">
    <tr>
        <td class="period"></td>
        <td class="price"></td>
    </tr>
</template>