{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-build",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["build"],
      "include": ["**/*.cs"],
      "filteringRule": "staged"
    },
    {
      "name": "dotnet-format",
      "group": "pre-push",
      "command": "dotnet",
      "args": ["format", "StromligningApp.csproj", "--verify-no-changes"]
    },
    {
      "name": "dotnet-test",
      "group": "pre-push",
      "command": "dotnet",
      "args": ["test"]
    }
  ]
}
